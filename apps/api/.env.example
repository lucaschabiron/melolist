# Postgres connection string.
DATABASE_URL=postgres://postgres:test@localhost:5432/postgres

# Signing secret for sessions. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-openssl-rand-base64-32

# Public URL of this API. Used by better-auth for callbacks.
BETTER_AUTH_URL=http://localhost:3000

# Public URL of the web app. Used for CORS + better-auth trustedOrigins.
APP_URL=http://localhost:3001

# Parent domain for session cookies when API and web live on different
# subdomains (e.g. api.melolist.com + melolist.com). Leave unset in dev.
# COOKIE_DOMAIN=.melolist.com

# Mailjet credentials for transactional email (verification, password reset).
MAILJET_API_KEY=replace-me
MAILJET_SECRET_KEY=replace-me

# Port the server listens on. Railway injects this automatically; optional locally.
# PORT=3000
