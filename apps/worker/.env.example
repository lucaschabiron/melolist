# Postgres connection string. Same as the API's.
DATABASE_URL=postgres://postgres:test@localhost:5432/postgres

# Redis connection string. Must point at the same instance the API uses —
# both the BullMQ queue and the MusicBrainz rate limiter share Redis state.
REDIS_URL=redis://localhost:6379

# User-Agent MusicBrainz requires on every request (their ToS). Include an app
# name + contact. Example: "MeloList/0.1.0 ( contact@melolist.com )"
MUSICBRAINZ_USER_AGENT=MeloList/0.1.0 ( contact@melolist.com )
