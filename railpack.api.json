{
    "$schema": "https://schema.railpack.com",
    "packages": {
        "bun": "1.3.12",
        "node": "22"
    },
    "caches": {
        "bun-install": {
            "directory": "/root/.bun/install/cache",
            "type": "shared"
        }
    },
    "steps": {
        "install": {
            "inputs": [{ "local": true, "include": ["."] }],
            "caches": ["bun-install"],
            "commands": [
                {
                    "cmd": "bun install --frozen-lockfile",
                    "customName": "Install workspace dependencies"
                }
            ]
        }
    },
    "deploy": {
        "inputs": [{ "step": "install" }],
        "startCommand": "cd apps/api && bunx drizzle-kit migrate && bun run src/index.ts"
    }
}
