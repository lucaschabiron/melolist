{
    "$schema": "https://schema.railpack.com",
    "packages": {
        "bun": "1.3.12",
        "node": "22"
    },
    "caches": {
        "bun-install": {
            "directory": "/root/.bun/install/cache",
            "type": "shared"
        },
        "next-build": {
            "directory": "/app/apps/web/.next/cache",
            "type": "shared"
        }
    },
    "steps": {
        "install": {
            "inputs": [{ "local": true, "include": ["."] }],
            "caches": ["bun-install"],
            "commands": [
                {
                    "cmd": "bun install --frozen-lockfile",
                    "customName": "Install workspace dependencies"
                }
            ]
        },
        "build": {
            "inputs": [{ "step": "install" }],
            "caches": ["next-build"],
            "commands": [
                {
                    "cmd": "cd apps/web && bun run build",
                    "customName": "Next build"
                }
            ]
        }
    },
    "deploy": {
        "inputs": [{ "step": "build" }],
        "startCommand": "cd apps/web && bun run start",
        "variables": {
            "NODE_ENV": "production"
        }
    }
}
