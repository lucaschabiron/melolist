{
    "$schema": "https://schema.railpack.com",
    "packages": {
        "bun": "1.3.12",
        "node": "22"
    },
    "steps": {
        "build": {
            "commands": [
                "cd apps/web && bun run build"
            ]
        }
    },
    "deploy": {
        "startCommand": "cd apps/web && bun run start",
        "variables": {
            "NODE_ENV": "production"
        }
    }
}
