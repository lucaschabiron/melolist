meta {
  name: 04 - Get artist release-groups
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/catalog/artists/{{beatlesArtistMbid}}/release-groups
}

headers {
  Cookie: better-auth.session_token={{sessionCookie}}
}

docs {
  Returns artist + paginated RG list. If the artist isn't seeded yet, also
  returns 202 with a fetch-artist jobId (fetch-artist includes discography).
}
